{
      "rewrites": [
            {
                  "source": "/((?!api|_next|.*\\.).*)",
                  "destination": "/index.html"
            }
      ],
      "headers": [
            {
                  "source": "/site.webmanifest",
                  "headers": [
                        {
                              "key": "Content-Type",
                              "value": "application/manifest+json"
                        }
                  ]
            },
            {
                  "source": "/(.*)",
                  "headers": [
                        {
                              "key": "Content-Security-Policy",
                              "value": "default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; connect-src 'self' https: http: ws: wss:;"
                        },
                        {
                              "key": "X-Frame-Options",
                              "value": "DENY"
                        },
                        {
                              "key": "X-Content-Type-Options",
                              "value": "nosniff"
                        },
                        {
                              "key": "Permissions-Policy",
                              "value": "camera=(), microphone=(), geolocation=()"
                        },
                        {
                              "key": "Referrer-Policy",
                              "value": "strict-origin-when-cross-origin"
                        }
                  ]
            }
      ]
}